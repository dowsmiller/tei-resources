<TEI xmlns="http://www.tei-c.org/ns/1.0" xml:id=""> <!-- Enter the manuscript ID -->
  <teiHeader>
    <fileDesc>
      <titleStmt>
        <title></title> <!-- Enter the shelfmark of the manuscript -->
        <title type="collection"></title> <!-- Enter the name of the collection -->

        <!-- Repeat this <respStmt> for each cataloguer or contributor -->
        <respStmt>
          <resp when=""></resp> <!-- e.g. "Cataloguer", with a year -->
          <persName></persName> <!-- Name of the person responsible -->
        </respStmt>
      </titleStmt>

      <publicationStmt>
        <publisher>
          <orgName type="department"></orgName> <!-- Department name -->
          <orgName type="unit"></orgName> <!-- Library or archives -->
          <orgName type="institution"></orgName> <!-- Parent institution -->
          <email></email> <!-- Contact email -->
        </publisher>
        <idno type=""></idno> <!-- Identifier for the manuscript ID (msID), collection, and catalogue -->
        <!-- Repeat <idno> as necessary -->
      </publicationStmt>

      <sourceDesc>
        <msDesc xml:id="" xml:lang="en">
          <msIdentifier>
            <country></country>
            <region type="county"></region>
            <settlement></settlement>
            <institution></institution>
            <repository></repository>
            <idno type="shelfmark"></idno>
            <idno type="ieArk"></idno>
          </msIdentifier>

          <msContents>
            <textLang mainLang=""></textLang> <!-- Use ISO codes in the attribute -->

            <msItem n="">
              <title></title>
              <locus from="" to=""></locus> <!-- The folios occupied by the item -->
              <note></note> <!-- Add any context or background information -->
              <incipit></incipit> <!-- Opening words -->
              <explicit></explicit> <!-- Closing words -->
              <!-- Optionally add <rubric> and <ref> elements -->
            </msItem>

            <!-- Repeat <msItem> for each item in the manuscript -->

          </msContents>

          <physDesc>
            <objectDesc form="codex">
              <supportDesc material=""> <!-- 'perg' = parchment, 'chart' = paper -->
                <support></support> <!-- e.g., parchment or paper -->
              </supportDesc>
            </objectDesc>

            <decoDesc>
              <decoNote type=""></decoNote> <!-- Types can be names or short names; add optional <locus> elements as required -->
              <!-- Repeat <decoNote> for each type of decoration in the manuscript -->
            </decoDesc>
          </physDesc>

          <history>
            <origin>
              <country></country>
              <origDate notBefore="" notAfter=""></origDate>
            </origin>

            <provenance></provenance> <!-- Add optional <persName> elements as required -->
            <!-- Repeat <provenance> elements for each instance of ownership history -->

            <acquisition when=""></acquisition> <!-- Acquisition date and details -->
          </history>
        </msDesc>
      </sourceDesc>
    </fileDesc>
  </teiHeader>
  <body><p/></body>
</TEI>
